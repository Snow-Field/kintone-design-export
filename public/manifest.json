{
  "manifest_version": 3,
  "name": "kintone Design Export",
  "version": "1.0.1",
  "permissions": ["activeTab", "scripting"],
  "host_permissions": ["https://*.cybozu.com/*"],
  "action": {
    "default_popup": "src/app/popup/popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://*.cybozu.com/k/*"],
      "js": ["src/features/exportApp/content.ts"]
    }
  ]
}
